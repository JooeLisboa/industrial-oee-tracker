# SQLAlchemy URL (Neon compatible)
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/oee

# Flask/JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_HOURS=12
FLASK_ENV=development

# Allowed frontend origins (comma separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://seu-dominio.com

# Seed admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
