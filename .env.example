# Database (dev default points to docker-compose db service)
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/oee

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_HOURS=12

# CORS (comma separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://seu-dominio.com

# Default admin (seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Exposed ports in docker-compose dev
API_PORT=5000
WEB_PORT=5173
